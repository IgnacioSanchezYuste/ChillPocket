# =====================================================
# Finanzas API · .htaccess
# - CORS a nivel de Apache (responde el preflight antes de Slim).
# - Rewrite a index.php para que el routing siempre funcione.
# =====================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /API_Finanzas/

    # Preflight OPTIONS: cortocircuito 204 (No Content) sin reescritura ni
    # Location. `R=200`/`R=200,L` con `R=` en mayúscula hace que Apache
    # responda con un redirect HTTP (302 con Location al propio URL); el
    # navegador entonces vuelve a pedir el endpoint con GET y Slim devuelve
    # 405 "Método no permitido". El patrón estándar es `R=204` (sin body,
    # sin Location), y los headers CORS los pone el bloque Header de abajo.
    RewriteCond %{REQUEST_METHOD} =OPTIONS
    RewriteRule ^ - [R=204,L]

    # Redirigir todo lo que no sea archivo/directorio real a index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Authorization, Content-Type, Accept, Origin, X-Requested-With"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

# Forzar que las respuestas 204/200 de OPTIONS no se cacheen mal
<IfModule mod_env.c>
    SetEnv no-gzip 1
</IfModule>
