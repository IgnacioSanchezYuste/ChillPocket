# ChillPocket · variables de entorno (Expo)
# Copia este archivo como .env y rellena los valores reales.
# Para builds EAS los valores se inyectan desde eas.json (perfiles dev/preview/production).

# Backend
EXPO_PUBLIC_API_URL=https://ignaciosanchezyuste.es/API_Finanzas

# Google OAuth
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# RevenueCat (Fase 2 · billing). Una clave por plataforma.
# RevenueCat Dashboard → Project → API keys → "Public app-specific API keys".
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
